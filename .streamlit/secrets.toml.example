# =============================================================================
# FOR HIM — Streamlit secrets 템플릿
# =============================================================================
# 사용법: 이 파일을 그대로 복사해 값만 채운 뒤,
#   - 로컬 실행: 같은 폴더에 secrets.toml 로 저장  (.gitignore 로 커밋 방지됨)
#   - Streamlit Community Cloud: 앱 → Manage app → Settings → Secrets 에 붙여넣기
#
# 실제 키 값은 절대 git 에 커밋하지 마세요. (이 .example 파일에는 값이 없습니다)
# 어떤 앱이 무엇을 쓰는지: SECRETS.md 참고.
# =============================================================================

# --- 1) Supabase (커뮤니티 글/댓글 공유용) ---------------------------------
# Supabase 대시보드 → Project Settings → API 에서 확인.
# URL 예시(현재 프로젝트): https://oyekdzxedtbiartqntum.supabase.co
SUPABASE_URL = "https://<프로젝트>.supabase.co"
# publishable(anon) 키. 예: sb_publishable_xxxxxxxx  (Bearer 로 클라이언트에서 사용)
SUPABASE_ANON_KEY = "<supabase-anon-or-publishable-key>"

# --- 2) 구글 로그인 (Streamlit 네이티브 OIDC / st.login) --------------------
# 반드시 최상위 [auth] 블록. (이름있는 provider [auth.google] 아님 → st.login() 인자 없이 호출)
[auth]
# 이 앱의 URL + /oauth2callback  (앱마다 URL 이 다르면 값도 달라야 함!)
redirect_uri = "https://<이-앱의-URL>/oauth2callback"
# 세션 쿠키 서명용 임의의 긴 문자열. 아무 랜덤값이나(예: openssl rand -hex 32).
cookie_secret = "<임의의-긴-랜덤-문자열>"
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
client_id = "<xxxxxxxx>.apps.googleusercontent.com"
client_secret = "<GOCSPX-...>"
# 구글은 고정값.
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
